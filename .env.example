# ==============================================================
# Tienda Perritos - Ejemplo de variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# Este archivo SI se puede subir al repositorio (sin secretos).
# ==============================================================

# BASE DE DATOS
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=tienda_perritos
MYSQL_USER=alumno
MYSQL_PASSWORD=

# BACKEND - Configuración de conexión
DB_HOST=db
DB_USER=root
DB_PASSWORD=
DB_NAME=tienda_perritos
DB_PORT=3306
PORT=3001

# PUERTOS OPERATIVOS DE CONTENEDORES
FRONTEND_PORT=80
BACKEND_PORT=3001
DB_PORT_EXPOSED=3306

# AWS ECS FARGATE (Solo referencia, en producción se inyectan dinámicamente)
AWS_REGION=us-east-1
AWS_ECS_CLUSTER=cluster-tienda-perritos

# REPOSITORIOS EN AMAZON ECR (Nomenclatura exacta del clúster)
ECR_REPO_FRONTEND=tienda-perritos-frontend
ECR_REPO_BACKEND=tienda-perritos-backend
ECR_REPO_DB=tienda-perritos-db