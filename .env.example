# ==============================================================
# Tienda Perritos - Ejemplo de variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# Este archivo SI se puede subir al repositorio (sin secretos).
# ==============================================================


# BASE DE DATOS
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=tienda_perritos
MYSQL_USER=alumno
MYSQL_PASSWORD=

# BACKEND
DB_HOST=db
DB_USER=root
DB_PASSWORD=
DB_NAME=tienda_perritos
DB_PORT=3306
PORT=3001

# PUERTOS LOCALES
FRONTEND_PORT=8080
BACKEND_PORT=3001
DB_PORT_EXPOSED=3306

# AWS (solo referencia, en CI/CD se usan GitHub Secrets)
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=
EKS_NAMESPACE=tienda

# ECR
ECR_REPO_FRONTEND=tienda-frontend
ECR_REPO_BACKEND=tienda-backend
ECR_REPO_DB=tienda-db
